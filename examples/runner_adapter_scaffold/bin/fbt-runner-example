#!/usr/bin/env python3
"""Minimal fbt stdio JSON-RPC runner adapter scaffold."""

from __future__ import annotations

import json
from pathlib import Path
import sys
from typing import Any


def write(message: dict[str, Any]) -> None:
    sys.stdout.write(json.dumps(message, separators=(",", ":"), sort_keys=True) + "\n")
    sys.stdout.flush()


def respond(request_id: str | None, result: dict[str, Any]) -> None:
    write({"jsonrpc": "2.0", "id": request_id, "result": result})


def notify(method: str, params: dict[str, Any]) -> None:
    write({"jsonrpc": "2.0", "method": method, "params": params})


def fail(request_id: str | None, code: int, message: str) -> None:
    write({"jsonrpc": "2.0", "id": request_id, "error": {"code": code, "message": message}})


def is_directory_artifact(artifact_type: str) -> bool:
    return artifact_type == "directory" or artifact_type.endswith("_directory")


def render_candidate(params: dict[str, Any], output: dict[str, Any]) -> str:
    """Replace this function with a real provider, agent, or tool call."""
    transform = params.get("transform", {})
    inputs = params.get("inputs", [])
    assets = params.get("assets", [])
    name = output.get("name", "output")

    lines = [
        f"# {name}",
        "",
        "Generated by the fbt runner adapter scaffold.",
        "",
        "## Transform",
        "",
        f"- name: {transform.get('name', 'unknown')}",
        f"- type: {transform.get('type', 'unknown')}",
        "",
        "## Inputs",
        "",
    ]
    for item in inputs:
        if isinstance(item, dict):
            lines.append(f"- {item.get('unique_id', item.get('name', 'input'))}")
    if not inputs:
        lines.append("- none")

    lines.extend(["", "## Assets", ""])
    for item in assets:
        if isinstance(item, dict):
            lines.append(f"- {item.get('unique_id', item.get('name', 'asset'))}")
    if not assets:
        lines.append("- none")

    lines.append("")
    return "\n".join(lines)


def run_transform(request_id: str | None, params: dict[str, Any]) -> None:
    transform_run_id = params.get("transform_run_id", "")
    work = params.get("work", {})
    output_root_value = work.get("outputs")
    if not isinstance(output_root_value, str) or not output_root_value:
        fail(request_id, -32602, "params.work.outputs is required")
        return

    output_root = Path(output_root_value)
    output_root.mkdir(parents=True, exist_ok=True)
    declared_outputs = params.get("outputs") or [
        {"name": "output", "artifact_type": "markdown", "declared_path": "target/artifacts/output.md"}
    ]

    notify(
        "fbt/event",
        {
            "request_id": request_id,
            "transform_run_id": transform_run_id,
            "event_type": "progress",
            "level": "info",
            "message": "runner adapter scaffold generating outputs",
        },
    )

    candidates: list[dict[str, Any]] = []
    for declared in declared_outputs:
        if not isinstance(declared, dict):
            continue
        name = str(declared.get("name") or "output")
        artifact_type = str(declared.get("artifact_type") or "markdown")
        candidate_path = output_root / name
        if is_directory_artifact(artifact_type):
            candidate_path.mkdir(parents=True, exist_ok=True)
            (candidate_path / "index.md").write_text(
                render_candidate(params, declared),
                encoding="utf-8",
            )
        else:
            candidate_path.parent.mkdir(parents=True, exist_ok=True)
            candidate_path.write_text(render_candidate(params, declared), encoding="utf-8")

        candidates.append(
            {
                "name": name,
                "artifact_type": artifact_type,
                "path": str(candidate_path),
                "declared_path": declared.get("declared_path", ""),
            }
        )

    notify(
        "fbt/outputCandidate",
        {
            "request_id": request_id,
            "transform_run_id": transform_run_id,
            "outputs": candidates,
        },
    )
    respond(
        request_id,
        {
            "status": "success",
            "transform_run_id": transform_run_id,
            "outputs": candidates,
            "warnings": [],
        },
    )


def initialize(request_id: str | None) -> None:
    respond(
        request_id,
        {
            "runner": {
                "name": "fbt-runner-example",
                "version": "0.1.0",
                "language": "python",
            },
            "protocol": {
                "version": "0.1",
                "framing": "jsonl",
            },
            "capabilities": {
                "transform_types": ["llm", "agent", "command"],
                "artifact_types": ["markdown", "markdown_directory", "text", "directory"],
                "stream_events": True,
                "output_candidates": True,
                "supports_cancel": True,
            },
        },
    )


def main() -> int:
    for line in sys.stdin:
        if not line.strip():
            continue
        try:
            request = json.loads(line)
        except json.JSONDecodeError as exc:
            fail(None, -32700, f"parse error: {exc}")
            continue

        if not isinstance(request, dict):
            fail(None, -32600, "request must be a JSON object")
            continue

        request_id = request.get("id")
        method = request.get("method")
        if method == "initialize":
            initialize(request_id)
        elif method == "initialized":
            continue
        elif method == "fbt/runTransform":
            params = request.get("params")
            if isinstance(params, dict):
                run_transform(request_id, params)
            else:
                fail(request_id, -32602, "params must be an object")
        elif method == "$/cancelRequest":
            return 0
        else:
            fail(request_id, -32601, f"method not found: {method}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
