{
  "$defs": {
    "artifact_type": {
      "anyOf": [
        {
          "enum": [
            "binary",
            "directory",
            "docx",
            "docx_directory",
            "html",
            "json",
            "jsonl_directory",
            "markdown",
            "markdown_directory",
            "pdf",
            "text",
            "xlsx",
            "xlsx_directory"
          ]
        },
        {
          "pattern": "^x\\..+",
          "type": "string"
        }
      ],
      "description": "Built-in artifact type alias or extension type starting with x."
    },
    "runner": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "capabilities": {
          "additionalProperties": true,
          "type": "object"
        },
        "command": {
          "type": "string"
        },
        "config": {
          "additionalProperties": true,
          "type": "object"
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "protocol": {
          "enum": [
            "stdio_jsonrpc"
          ],
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "protocol",
        "command"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fbt.dev/fbt/resource-file/v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Schema for YAML files under source, transform, asset, policy, and eval paths.",
  "minProperties": 1,
  "properties": {
    "artifacts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "contract": {
            "additionalProperties": true,
            "description": "Free-form metadata passed through manifests and runner protocol; fbt core does not validate arbitrary contract semantics.",
            "type": "object"
          },
          "meta": {
            "additionalProperties": true,
            "type": "object"
          },
          "name": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": {
            "anyOf": [
              {
                "enum": [
                  "binary",
                  "directory",
                  "docx",
                  "docx_directory",
                  "html",
                  "json",
                  "jsonl_directory",
                  "markdown",
                  "markdown_directory",
                  "pdf",
                  "text",
                  "xlsx",
                  "xlsx_directory"
                ]
              },
              {
                "pattern": "^x\\..+",
                "type": "string"
              }
            ],
            "description": "Built-in artifact type alias or extension type starting with x."
          }
        },
        "required": [
          "name",
          "type",
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "assets": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "meta": {
            "additionalProperties": true,
            "type": "object"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "variables": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name",
          "type",
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "evals": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "config": {
            "additionalProperties": true,
            "type": "object"
          },
          "grants_confidence": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "runner": {
            "type": "string"
          },
          "type": {
            "description": "deterministic evals run in fbt core. semantic and llm_judge evals are reserved delegated shapes; MVP builds record them as skipped and grant no confidence. Use an external judge transform for an active model-based quality gate.",
            "enum": [
              "deterministic",
              "llm_judge",
              "semantic"
            ]
          }
        },
        "required": [
          "name",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "policies": {
      "items": {
        "additionalProperties": false,
        "properties": {
