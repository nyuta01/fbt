                  "type": "object"
                },
                "name": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "type": {
                  "anyOf": [
                    {
                      "enum": [
                        "binary",
                        "directory",
                        "docx",
                        "docx_directory",
                        "html",
                        "json",
                        "jsonl_directory",
                        "markdown",
                        "markdown_directory",
                        "pdf",
                        "text",
                        "xlsx",
                        "xlsx_directory"
                      ]
                    },
                    {
                      "pattern": "^x\\..+",
                      "type": "string"
                    }
                  ],
                  "description": "Built-in artifact type alias or extension type starting with x."
                }
              },
              "required": [
                "name",
                "type",
                "path"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "policy": {
            "type": "string"
          },
          "runner": {
            "type": "string"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "tools": {
            "items": {
              "type": "string"
            },
            "type": "array"
