                  "properties": {
                    "confidence": {
                      "type": "string"
                    },
                    "evals": {
                      "additionalProperties": true,
                      "type": "object"
                    }
                  },
                  "type": "object"
                },
                "source": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "meta": {
            "additionalProperties": true,
            "type": "object"
          },
          "model": {
            "additionalProperties": true,
            "type": "object"
          },
          "name": {
            "type": "string"
          },
          "outputs": {
            "items": {
              "additionalProperties": false,
              "properties": {
