                },
                "name": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "tags": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "tests": {
                  "items": {},
                  "type": "array"
                },
                "type": {
                  "anyOf": [
                    {
                      "enum": [
                        "binary",
                        "directory",
                        "docx",
                        "docx_directory",
                        "html",
                        "json",
                        "jsonl_directory",
                        "markdown",
                        "markdown_directory",
                        "pdf",
                        "text",
                        "xlsx",
                        "xlsx_directory"
                      ]
                    },
                    {
                      "pattern": "^x\\..+",
                      "type": "string"
                    }
                  ],
                  "description": "Built-in artifact type alias or extension type starting with x."
                }
              },
              "required": [
                "name",
                "type",
                "path"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "description": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "artifacts"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "transforms": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "agent": {
            "type": "string"
          },
          "assets": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "path": {
