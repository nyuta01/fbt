      "items": {
        "additionalProperties": false,
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "capabilities": {
            "additionalProperties": true,
            "type": "object"
          },
          "command": {
            "type": "string"
          },
          "config": {
            "additionalProperties": true,
            "type": "object"
          },
          "cwd": {
            "type": "string"
          },
          "env": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "enum": [
              "stdio_jsonrpc"
            ],
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "type",
          "protocol",
          "command"
